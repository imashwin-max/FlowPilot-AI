NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
GEMINI_API_KEY=your-google-gemini-api-key

# Required to protect the Approve/Reject endpoint. Pick any private string
# and share it only with people who should be able to act as "Manager" in
# the demo (e.g. your own team during the hackathon). Without this set,
# the approve/reject API is open to anyone - the app will log a warning
# on every request until it's configured.
MANAGER_ACCESS_CODE=choose-a-private-string

# Clerk Authentication API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
CLERK_SECRET_KEY=your-clerk-secret-key

# Clerk Route Routing Settings
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Required for the /admin page. Pick a different private string than
# MANAGER_ACCESS_CODE. This replaces a previous hardcoded password that was
# committed to source control - never hardcode secrets in application code.
ADMIN_ACCESS_CODE=choose-a-different-private-string

